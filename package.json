{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "main": "build/main.js",
  "homepage": "http:./",
  "author": "",
  "build": {
    "appId": "com.gym.management",
    "productName": "Gym Management System",
    "directories": {
      "output": "dist"
    },
    "extraMetadata": {
      "main": "build/main.js"
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "m2datastudio-dsds",
        "repo": "gym"
      }
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@prisma/client": "^5.21.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "antd": "^5.20.1",
    "body-parser": "^1.20.3",
    "call-bind-apply-helpers": "^1.0.1",
    "chart.js": "^4.4.3",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "electron-is-dev": "^3.0.1",
    "express": "^4.21.0",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jwt-decode": "^4.0.0",
    "localforage": "^1.10.0",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.1.7",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.2.1",
    "react-responsive": "^10.0.0",
    "react-router-dom": "^6.26.0",
    "react-scripts": "5.0.1",
    "electron-updater": "^6.3.9",
    "react-webcam": "^7.2.0",
    "styled-components": "^6.1.12",
    "web-vitals": "^2.1.4",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0"
  
  },
  "scripts": {
    "start-react": "react-scripts start",
    "startlin-react": "PORT=9000 BROWSER=none react-scripts start",
    "start-electron": "nodemon --watch ./public/* --exec \"electron .\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "electron-builder install-app-deps",
    "build-win": "cross-env NODE_ENV=production npm run build && electron-builder --win",
    "release-win": "cross-env NODE_ENV=production npm run build && electron-builder --win --publish always",
    "start": "node server.js",
    "prisma:studio": "prisma studio --schema=public/API/V1/prisma/schema.prisma"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "prisma": "^5.21.1"
  },
  "description": "This project was bootstrapped with [Create React App](https://github.com/facebook/create-react-app).",
  "license": "ISC"
}
